<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Reportes de ventas</h1>
</div>

<%= render "filters" %>

<% if (@total_sales.to_i + @total_cancelled.to_i).zero? %>
  <div class="card shadow-sm p-4 mb-4">
    <p class="mb-0">
      No se encontraron ventas para los filtros seleccionados.
      Probá ampliar el rango de fechas o quitar algún filtro.
    </p>
  </div>
<% end %>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card shadow-sm p-3">
      <h2 class="h6 mb-2">Total recaudado</h2>
      <p class="h4 mb-0">$ <%= number_with_precision(@total_revenue || 0, precision: 2) %></p>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm p-3">
      <h2 class="h6 mb-2">Cantidad de ventas realizadas</h2>
      <p class="h4 mb-0"><%= @total_sales || 0 %></p>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm p-3">
      <h2 class="h6 mb-2">Promedio de importe por venta</h2>
      <p class="h4 mb-0">
        $ <%= number_with_precision(@average_sale || 0, precision: 2) %>
      </p>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm p-3">
      <h2 class="h6 mb-2">Cantidad de productos vendidos</h2>
      <p class="h4 mb-0"><%= @total_items || 0 %></p>
    </div>
  </div>
</div>

<div class="card shadow-sm p-4 mt-4">
  <h2 class="h5 mb-3">Ventas por tipo de producto</h2>

  <% if @sales_by_type.present? %>
    <%= pie_chart @sales_by_type,
      colors: ["#c20406", "#8a0000"] %>
  <% else %>
    <p>No hay datos para mostrar.</p>
  <% end %>
</div>

<div class="card shadow-sm p-4 mt-4">
  <h2 class="h5 mb-3">Ventas por género musical</h2>

  <% if @sales_by_genre.present? %>
    <%= column_chart @sales_by_genre %>
  <% else %>
    <p>No hay datos para mostrar.</p>
  <% end %>
</div>

<div class="card shadow-sm p-4 mt-4">
  <h2 class="h5 mb-3">Top 5 productos más vendidos</h2>

  <% if @top_products.present? %>
    <%= bar_chart @top_products %>
  <% else %>
    <p>No hay datos para mostrar.</p>
  <% end %>
</div>
